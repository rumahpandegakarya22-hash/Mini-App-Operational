# Salin ke .env.local dan isi. JANGAN commit .env.local.

# Auth
JWT_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Login/self-registration via Google (OAuth Client BEDA dari Service Account di bawah — buat di
# Google Cloud Console > APIs & Services > Credentials > OAuth client ID > Web application).
# Authorized redirect URI: {APP_BASE_URL}/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APP_BASE_URL=http://localhost:3000

# Google Service Account (share semua spreadsheet & folder Drive ke email service account ini)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Private key: satu baris, \n literal untuk baris baru
GOOGLE_PRIVATE_KEY=

# Spreadsheet BARU (buat manual, lalu isi ID-nya)
SHEET_ID_AUDIT_LOG=
SHEET_ID_PINDAH_KAMAR=
SHEET_ID_CHECKOUT=

# Apps Script Invoice (deploy sebagai Web App, isi URL + token)
APPS_SCRIPT_INVOICE_DP_URL=
APPS_SCRIPT_INVOICE_SEWA_URL=
APPS_SCRIPT_TOKEN=

# Folder Drive untuk upload (ID folder)
DRIVE_FOLDER_PENGHUNI=
DRIVE_FOLDER_PEMBAYARAN=
DRIVE_FOLDER_NOTA=
DRIVE_FOLDER_FEEDBACK=
DRIVE_FOLDER_MAINTENANCE=
